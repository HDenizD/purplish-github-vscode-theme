{
  "name": "purplish-github-theme",
  "displayName": "Purplish — GitHub Dark & Light",
  "description": "A more purple variant of the GitHub theme for VS Code",
  "version": "1.0.5",
  "publisher": "dederezzed",
  "license": "MIT",
  "icon": "icon.png",
  "galleryBanner": {
    "color": "#1b1f23",
    "theme": "dark"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/HDenizD/purplish-github-vscode-theme"
  },
  "bugs": {
    "url": "https://github.com/HDenizD/purplish-github-vscode-theme/issues"
  },
  "engines": {
    "vscode": "^1.43.0"
  },
  "categories": [
    "Themes"
  ],
  "keywords": [
    "theme",
    "github",
    "purple",
    "dark",
    "light"
  ],
  "contributes": {
    "themes": [
      {
        "label": "Purplish GitHub Light",
        "uiTheme": "vs",
        "path": "./themes/light-default.json"
      },
      {
        "label": "Purplish GitHub Dark",
        "uiTheme": "vs-dark",
        "path": "./themes/dark-default.json"
      }
    ]
  },
  "devDependencies": {
    "@changesets/changelog-github": "^0.4.1",
    "@changesets/cli": "^2.17.0",
    "@primer/primitives": "7.10.0",
    "chroma-js": "^2.1.2",
    "color": "^3.1.2",
    "nodemon": "^2.0.3",
    "vsce": "^1.100.1"
  },
  "scripts": {
    "start": "nodemon --watch src src/index.js",
    "build": "node src/index.js",
    "package": "node -e \"require('fs').mkdirSync('build',{recursive:true})\" && vsce package -o ./build/purplish-github-theme.vsix",
    "prepublishOnly": "npm run build && vsce publish",
    "release": "changeset publish"
  },
  "publishConfig": {
    "access": "public"
  }
}
